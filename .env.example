POSTGRES_DB=football_tg
POSTGRES_USER=football_user
POSTGRES_PASSWORD=football_pass
POSTGRES_PORT=5433
DATABASE_URL=postgresql+psycopg2://football_user:football_pass@postgres:5432/football_tg
REDIS_URL=redis://redis:6379/0

APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
BACKEND_CORS_ORIGINS=https://your-frontend-domain,http://localhost:5173,http://127.0.0.1:5173

TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHANNEL_ID=@your_channel
TELEGRAM_CHANNEL_URL=https://t.me/your_channel
TELEGRAM_ALLOWED_USER_ID=123456789
TELEGRAM_INIT_DATA_TTL_SECONDS=86400
VK_ACCESS_TOKEN=your_vk_access_token
VK_GROUP_ID=your_vk_group_id
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

LOCAL_STORAGE_PATH=./storage
PARSER_INTERVAL_MINUTES=120
PARSER_MAX_ITEM_AGE_HOURS=24
AI_SERVICE_MODE=ollama
AI_OLLAMA_BASE_URL=http://host.docker.internal:11434
AI_OLLAMA_MODEL=qwen2.5:3b
AI_REQUEST_TIMEOUT_SECONDS=90
AI_OLLAMA_KEEP_ALIVE=10m
AI_OLLAMA_TEMPERATURE=0.35
AI_OLLAMA_TOP_P=0.9
TRANSLATION_SERVICE_MODE=google
TRANSLATION_TARGET_LANGUAGE=ru
AI_SYSTEM_PROMPT=Ты редактор футбольного Telegram-канала. Сделай из новости короткий факт на русском языке. Обычно это 1-2 предложения, только главное и без воды.
