POSTGRES_DB=football_tg
POSTGRES_USER=football_user
POSTGRES_PASSWORD=football_pass
DATABASE_URL=postgresql+psycopg2://football_user:football_pass@postgres:5432/football_tg
REDIS_URL=redis://redis:6379/0

APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHANNEL_ID=@your_channel
TELEGRAM_WEBAPP_SECRET=your_webapp_secret
TELEGRAM_ALLOWED_USER_ID=123456789

LOCAL_STORAGE_PATH=/app/storage
AI_SERVICE_MODE=stub

